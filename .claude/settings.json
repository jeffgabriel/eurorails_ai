{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/.claude/hooks/compounds-check-cli.sh",
            "timeout": 15
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/.claude/hooks/compounds-report-inject.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read|Glob|Grep|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/.claude/hooks/compounds-pre-explore.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/.claude/hooks/compounds-pre-bash.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/.claude/hooks/compounds-pre-write.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__compounds-dev__implement_task_finalize",
        "hooks": [
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/.claude/hooks/compounds-pre-finalize.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__compounds-dev__plan_change",
        "hooks": [
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/.claude/hooks/compounds-post-plan-change.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__compounds-dev__gen_spec",
        "hooks": [
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/.claude/hooks/compounds-post-gen-spec.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__compounds-dev__gen_master_spec",
        "hooks": [
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/.claude/hooks/compounds-post-gen-master-spec.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__compounds-dev__gen_project_spec",
        "hooks": [
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/.claude/hooks/compounds-post-gen-project-spec.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__compounds-dev__validate_master_spec",
        "hooks": [
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/.claude/hooks/compounds-post-validate-master-spec.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__compounds-dev__validate_project_specs",
        "hooks": [
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/.claude/hooks/compounds-post-validate-project-specs.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__compounds-dev__generate_tasks",
        "hooks": [
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/.claude/hooks/compounds-post-generate-tasks.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__compounds-dev__implement_task",
        "hooks": [
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/.claude/hooks/compounds-post-implement-task.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__compounds-dev__implement_task_finalize",
        "hooks": [
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/.claude/hooks/compounds-post-implement-task-finalize.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__compounds-dev__implement_all_tasks",
        "hooks": [
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/.claude/hooks/compounds-post-implement-all-tasks.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__compounds-dev__add_task",
        "hooks": [
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/.claude/hooks/compounds-post-add-task.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__compounds-dev__create_project",
        "hooks": [
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/.claude/hooks/compounds-post-create-project.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/.claude/hooks/compounds-user-prompt-submit.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
